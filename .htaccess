RewriteEngine On

AddType text/markdown .md
AddCharset utf-8 .md

<IfModule mod_headers.c>
    Header always merge Vary "Accept"
    Header always set X-Markdown-Tokens "1200" "expr=%{CONTENT_TYPE} =~ m#^text/markdown(?:;|$)#"
    Header always set Link "</index.md>; rel=\"alternate\"; type=\"text/markdown\", </llms.txt>; rel=\"describedby\"; type=\"text/plain\", </.well-known/agent.json>; rel=\"describedby\"; type=\"application/json\"" "expr=%{REQUEST_URI} in {'/','/index','/index.html','/index.md'}"
</IfModule>

# Serve markdown variants to agents that explicitly request them.
RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
RewriteCond %{REQUEST_URI} ^/?$
RewriteCond %{DOCUMENT_ROOT}/index.md -f
RewriteRule ^$ index.md [L,T=text/markdown]

RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.md -f
RewriteRule ^(.+?)/?$ $1.md [L,T=text/markdown]

RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteCond %{DOCUMENT_ROOT}/$1.md -f
RewriteRule ^(.+)\.html$ $1.md [L,T=text/markdown]

# example.com/page will display the contents of example.com/page.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L,QSA]

# 301 from example.com/page.html to example.com/page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /.*\.html\ HTTP/
RewriteRule ^(.*)\.html$ /$1 [R=301,L]
